<resources>
  <!-- Tema da SplashScreen (já herdado de Theme.SplashScreen) -->
  <style name="Theme.nexa.Splash" parent="Theme.SplashScreen">
    <!-- Cor de fundo da splash (opcional) 
    -->
  <item name="windowSplashScreenBackground">@android:color/white</item>
  <!-- Ícone central da splash -->
  <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
  <!-- Tema que será aplicado depois da splash -->
  <item name="postSplashScreenTheme">@style/Theme.nexa</item>
  </style>
  
  <!-- Tema principal da atividade (sem ActionBar) -->
  <style name="Theme.nexa" parent="Theme.AppCompat.Light.NoActionBar">
    <item name="android:statusBarColor">@android: color/white</item> <item name="android:windowLightStatusBar" >true</item>
  </style>
</resources>